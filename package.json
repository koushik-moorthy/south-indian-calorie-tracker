{
  "name": "foodcal",
  "version": "1.0.0",
  "private": true,
  "description": "Estimate calories from South Indian food via text or photo (Next.js + Supabase + OpenAI, bring-your-own-key).",
  "license": "MIT",
  "homepage": "https://github.com/koushik-moorthy/south-indian-calorie-tracker#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/koushik-moorthy/south-indian-calorie-tracker.git"
  },
  "bugs": {
    "url": "https://github.com/koushik-moorthy/south-indian-calorie-tracker/issues"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "next": "^16.2.6",
    "openai": "^4.67.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
