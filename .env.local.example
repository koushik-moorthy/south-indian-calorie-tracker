# Copy this file to .env.local and fill in the values.

# Supabase — find these in your dashboard under Project Settings → API.
# The publishable (anon) key is safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Server-only secret to encrypt each user's OpenAI API key at rest (AES-256-GCM).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SETTINGS_ENC_KEY=base64-32-byte-secret

# --- Single-user mode (optional) -------------------------------------------
# Lock the app to a single account. Both vars are server-only (never exposed to
# the browser). See README → "Single-user mode" for the full guide.
#
#   SINGLE_USER_MODE=true   → only ALLOWED_EMAIL can sign in; sign-ups are
#                             hidden in the UI and refused server-side.
#   SINGLE_USER_MODE=false  → (default) normal multi-user behavior; sign-ups
#                             available again. No email restriction applies.
#
# Leave SINGLE_USER_MODE unset/false for a normal multi-user deployment.
# ALLOWED_EMAIL accepts a single address or a comma-separated list.
SINGLE_USER_MODE=false
ALLOWED_EMAIL=you@example.com
